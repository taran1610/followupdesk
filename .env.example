# Optional: canonical URL for Open Graph / metadata
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Copy to `.env.local` and fill in required values.
# Supabase is required for sign-in and data storage.

# --- Supabase (database + auth) ---
# When both of these are set, the app uses Supabase instead of the mock store.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Only needed for server-side admin tasks (not required for the MVP).
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI (AI follow-up generation) ---
# When set, the AI generator calls OpenAI. Otherwise it uses a built-in
# template engine so the feature always works.
OPENAI_API_KEY=
# Optional: override the model (defaults to gpt-4o-mini).
OPENAI_MODEL=

# --- Gmail / Email Brain ---
# Users connect via Google in Settings (Supabase OAuth: gmail.send + gmail.readonly).
# One-time platform setup in Google Cloud (same project as Supabase Google sign-in):
#   1. Enable Gmail API
#   2. Add scopes: gmail.send and gmail.readonly on OAuth consent screen
#   3. Add test users while in Testing mode (or publish + verify for production)
#   4. Optional server refresh tokens:
GOOGLE_GMAIL_CLIENT_ID=
GOOGLE_GMAIL_CLIENT_SECRET=
# Optional: HMAC secret for OAuth state (defaults to service role key).
GMAIL_OAUTH_STATE_SECRET=

# --- Resend (optional fallback — not used when Gmail is connected) ---
RESEND_API_KEY=

# --- Stripe (subscriptions) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs from Stripe Dashboard → Products (e.g. price_xxx)
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=
